---
import { Instagram, Linkedin, Facebook } from 'lucide-astro';
import ThemeToggle from './ThemeToggle.astro';
import { cdn } from '../config.ts';
---

<footer>
  <div class="container">
    <div class="footer-content">
      <!-- Sección 1: Logo -->
      <div class="footer-section logo-section">
        <img src=`${cdn}/menu-dark.png` alt="ACIMU Logo" class="footer-logo" />
      </div>

      <!-- Sección 2: Sitemap y Contacto -->
      <div class="footer-section sitemap-contact-section">
        <nav class="sitemap">
          <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/about">Acerca de</a></li>
            <li><a href="/portfolio">Portafolio</a></li>
            <li><a href="/quoter">Cotizador</a></li>
            <li><a href="/contact">Contacto</a></li>
          </ul>
        </nav>
      </div>

      <!-- Sección 3: Redes Sociales -->
      <div class="footer-section social-section">
        <div class="social">
          <a
            href="https://www.linkedin.com/company/arquitectos-cinco-uno"
            aria-label="Linkedin"
            target="_blank"
            ><Linkedin size={24} /><p class="social-name">LinkedIn</p></a
          >
          <a
            href="https://www.instagram.com/_acimu_"
            aria-label="Instagram"
            target="_blank"
            ><Instagram size={24} /><p class="social-name">Instagram</p></a
          >
          <a
            href="https://www.facebook.com/profile.php?id=61572375099518"
            aria-label="Instagram"
            target="_blank"
            ><Facebook size={24} /><p class="social-name">Facebook</p></a
          >
        </div>
        <div class="theme-toggle">
          <ThemeToggle />
        </div>
      </div>
    </div>

    <!-- Footer Bottom: Copyright -->
    <div class="footer-bottom">
      <div>
        <span>
          <img
            src="/payment-methods/deuna.svg"
            alt="deuna"
            style="height: 24px; vertical-align: middle;"
          />
        </span>
        <span>
          <img
            src="/payment-methods/datafast.svg"
            alt="deuna"
            style="height: 24px; vertical-align: middle;"
          />
        </span>
        <span>
          <img
            src="/payment-methods/visa.svg"
            alt="deuna"
            style="height: 24px; vertical-align: middle;"
          />
        </span>
        <span>
          <img
            src="/payment-methods/mastercard.svg"
            alt="deuna"
            style="height: 24px; vertical-align: middle;"
          />
        </span>
        <span>
          <img
            src="/payment-methods/amex.svg"
            alt="deuna"
            style="height: 24px; vertical-align: middle;"
          />
        </span>
        <span>
          <img
            src="/payment-methods/diners.svg"
            alt="deuna"
            style="height: 24px; vertical-align: middle;"
          />
        </span>
      </div>
      <div class="copy">
        <p>
          &copy; {new Date().getFullYear()} ACIMU. Todos los derechos reservados.
        </p>
        <p>
          Made with ❤️ by <a
            href="https://github.com/PabloWually"
            target="_blank">wually</a
          >
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    background-color: #2C3E50;
    padding: var(--spacing-xl) 0 1;
    opacity: 0.95;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .footer-content {
    padding-top: var(--spacing-lg);
  }

  .footer-section {
    display: flex;
    justify-content: center;
  }

  /* Sección 1: Logo */
  .logo-section {
    padding: var(--spacing-lg);
  }

  .footer-logo {
    width: 100%;
    max-width: 350px;
    height: auto;
  }

  /* Sección 2: Sitemap y Contacto */
  .sitemap-contact-section {
    flex-direction: column;
    align-items: center;
  }

  .sitemap {
    margin-bottom: var(--spacing-lg);
  }

  .sitemap ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: row;
    gap: var(--spacing-md);
  }

  .sitemap li a {
    color: var(--color-text-footer);
    text-decoration: none;
    transition: color 0.3s ease;
    font-size: 0.95rem;
  }

  .sitemap li a:hover {
    color: var(--color-muted);
  }

  /* Sección 3: Contacto */
  .contact-section {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact-section p {
    margin: var(--spacing-xs) 0;
    color: var(--color-text-footer);
    font-size: 0.95rem;
  }

  /* Sección 4: Redes Sociales */
  .social-section {
    flex-direction: column;
    align-items: center;
  }

  .social {
    display: flex;
    gap: var(--spacing-md);
    margin-top: var(--spacing-md);
  }

  .social a {
    width: 120px;
    color: var(--color-text-footer);
    transition:
      color 0.3s ease,
      transform 0.2s ease;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .social a:hover {
    color: var(--color-primary);
    transform: scale(1.1);
  }

  .theme-toggle {
    margin-top: var(--spacing-md);
    margin-bottom: var(--spacing-xs);
  }

  /* Footer Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(128, 128, 128, 0.2);
    padding-top: var(--spacing-md);
    text-align: center;
  }

  .copy {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin: 0;
  }
  
  .copy a {
    color: var(--color-text-footer);
    text-decoration: linen;
    font-weight: bold;
  }

  /* Layout para pantallas medianas y grandes */
  @media (min-width: 768px) {
    .footer-content {
      display: grid;
      grid-template-columns: 1fr 2fr 1fr;
      gap: var(--spacing-lg);
      align-items: center;
    }

    .logo-section {
      padding: 0;
      justify-content: flex-start;
    }

    .footer-logo {
      max-width: 250px;
    }

    .sitemap-contact-section {
      align-items: center;
    }

    .sitemap {
      margin-bottom: var(--spacing-md);
    }

    .sitemap ul {
      justify-content: center;
    }

    .contact-section {
      align-items: center;
    }

    .social-section {
      justify-content: center;
      align-items: center;
    }

    .social {
      flex-direction: column;
      align-items: center;
      margin-top: 0;
    }
  }

  @media (max-width: 480px) {
    footer {
      padding: var(--spacing-lg) 0 1;
    }

    .container {
      padding: 0 var(--spacing-sm);
    }

    .sitemap li a,
    .contact-section p {
      font-size: 0.85rem;
    }

    .social a {
      width: 30px;
    }

    .social-name {
      display: none;
    }

    .copy {
      font-size: 0.85rem;
    }
  }
</style>

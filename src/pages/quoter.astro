---
export const prerender = true;
import Layout from "@/layouts/Layout.astro";
import { 
  design, 
  electric, 
  hydro, 
  structural, 
  voz, 
  approval, 
  visit,
  obraNegraHormigon,
  obraNegraMetalica,
  obraGrisHormigon,
  obraGrisMetalica,
  obraBlancaHormigon,
  obraBlancaMetalica,
  obraHabitableHormigon,
  obraHabitableMetalica,
  llaveManoHormigon,
  llaveManoMetalica
} from "@/config";

const prices = {
  levantamiento: 0,
  disenoArq: design,
  planosElec: electric,
  planosHidro: hydro,
  planosEstr: structural,
  planosVoz: voz,
  aprobacion: approval,
  visita: visit,
  obraNegraHormigon,
  obraNegraMetalica,
  obraGrisHormigon,
  obraGrisMetalica,
  obraBlancaHormigon,
  obraBlancaMetalica,
  obraHabitableHormigon,
  obraHabitableMetalica,
  llaveManoHormigon,
  llaveManoMetalica
};
---

<Layout
  title="Cotizador de Proyectos - ACIMU | Calcula el Costo de tu Diseño o Construcción"
  description="Cotizador online gratuito para proyectos arquitectónicos y de construcción en Quito y Sangolquí. Calcula el costo de diseño arquitectónico, aprobación de planos y construcción por m²."
  keywords="cotizador arquitectura, cuanto cuesta diseño arquitectónico, precio construcción por m2, costo aprobación planos, cotizador construcción quito"
>
  <main class="container">
    <section class="quote-intro">
      <h1>Cotizador de Proyectos</h1>
      <p>
        Calcula un estimado para tu proyecto. Selecciona los servicios que
        necesitas e ingresa el área de construcción.
      </p>
    </section>

    <section class="quote-form-container">
      <form id="quote-form" class="quote-form">
        <!-- Servicio -->
        <div class="form-group">
          <label for="serviceType">Servicio</label>
          <div class="select-wrapper">
            <select id="serviceType" name="serviceType" required>
              <option value="arquitectura" selected>Arquitectura</option>
              <option value="construccion">Construcción</option>
            </select>
          </div>
        </div>

        <!-- Tipo de Proyecto -->
        <div class="form-group">
          <label for="projectType">Tipo de Proyecto</label>
          <div class="select-wrapper">
            <select id="projectType" name="projectType" required>
              <option value="" disabled selected>Selecciona una opción</option>
              <option value="residencial">Residencial</option>
              <option value="comercial">Comercial</option>
              <option value="otro">Otro</option>
            </select>
          </div>
        </div>

        <!-- Ciudad -->
        <div class="form-group">
          <label for="city">Ciudad</label>
          <input
            type="text"
            id="city"
            name="city"
            placeholder="Ej. Quito"
            required
          />
        </div>

        <!-- Dimensiones Grid -->
        <div class="form-group dimensions-grid">
          <div class="dimension-item">
            <label for="largo">Largo (m)</label>
            <input
              type="number"
              id="largo"
              name="largo"
              min="0"
              step="0.01"
              placeholder="0"
              required
            />
          </div>

          <div class="dimension-item dimension-separator">
            <span class="multiply-symbol">×</span>
          </div>

          <div class="dimension-item">
            <label for="ancho">Ancho (m)</label>
            <input
              type="number"
              id="ancho"
              name="ancho"
              min="0"
              step="0.01"
              placeholder="0"
              required
            />
          </div>

          <div class="dimension-item dimension-separator">
            <span class="equals-symbol">=</span>
          </div>

          <div class="dimension-item">
            <label for="area">Área (m²)</label>
            <input
              type="number"
              id="area"
              name="area"
              min="0"
              placeholder="0"
              readonly
              class="area-readonly"
            />
          </div>
        </div>

        <!-- Número de Pisos -->
        <div class="form-group">
          <label for="numPisos">Número de Pisos</label>
          <input
            type="number"
            id="numPisos"
            name="numPisos"
            min="1"
            placeholder="1"
            value="1"
            required
          />
        </div>

        <!-- Materialidad (solo para Construcción) -->
        <div class="form-group" id="materialidadGroup" style="display: none;">
          <label for="materialidad">Materialidad</label>
          <div class="select-wrapper">
            <select id="materialidad" name="materialidad">
              <option value="hormigon" selected>Hormigón Armado</option>
              <option value="metalica">Estructura Metálica</option>
            </select>
          </div>
        </div>

        <!-- Servicios Arquitectura -->
        <div class="form-group" id="serviciosArquitectura">
          <label class="services-label">Servicios Requeridos</label>
          <div class="checkbox-grid">
            <label class="checkbox-item">
              <input
                type="checkbox"
                name="service"
                value="disenoArq"
                data-price={prices.disenoArq}
              />
              <span>Diseño Arquitectónico</span>
            </label>

            <label class="checkbox-item">
              <input
                type="checkbox"
                name="service"
                value="planosElec"
                data-price={prices.planosElec}
              />
              <span>Planos Eléctricos</span>
            </label>

            <label class="checkbox-item">
              <input
                type="checkbox"
                name="service"
                value="planosHidro"
                data-price={prices.planosHidro}
              />
              <span>Planos Hidrosanitarios</span>
            </label>

            <label class="checkbox-item">
              <input
                type="checkbox"
                name="service"
                value="planosEstr"
                data-price={prices.planosEstr}
              />
              <span>Planos Estructurales</span>
            </label>

            <label class="checkbox-item">
              <input
                type="checkbox"
                name="service"
                value="planosVoz"
                data-price={prices.planosVoz}
              />
              <span>Planos Voz y Datos</span>
            </label>

            <label class="checkbox-item">
              <input
                type="checkbox"
                name="service"
                value="aprobacion"
                data-price={prices.aprobacion}
              />
              <span>Aprobación de Planos</span>
            </label>

            <label class="checkbox-item">
              <input
                type="checkbox"
                name="service"
                value="visita"
                data-price={prices.visita}
              />
              <span>Visita Técnica</span>
            </label>
          </div>
        </div>

        <!-- Servicios Construcción -->
        <div class="form-group" id="serviciosConstruccion" style="display: none;">
          <label class="services-label">Opciones de Construcción</label>
          <div class="radio-group">
            <label class="radio-item">
              <input
                type="radio"
                name="obraNivel"
                value="obraNegra"
                data-price-hormigon={prices.obraNegraHormigon}
                data-price-metalica={prices.obraNegraMetalica}
              />
              <span>
                <strong>Obra Negra</strong><br/>
                <small>Cimentación, contrapiso, columnas, vigas, losa</small>
              </span>
            </label>

            <label class="radio-item">
              <input
                type="radio"
                name="obraNivel"
                value="obraGris"
                data-price-hormigon={prices.obraGrisHormigon}
                data-price-metalica={prices.obraGrisMetalica}
              />
              <span>
                <strong>Obra Gris</strong><br/>
                <small>Paredes, enlucidos, masillados</small>
              </span>
            </label>

            <label class="radio-item">
              <input
                type="radio"
                name="obraNivel"
                value="obraBlanca"
                data-price-hormigon={prices.obraBlancaHormigon}
                data-price-metalica={prices.obraBlancaMetalica}
              />
              <span>
                <strong>Obra Blanca</strong><br/>
                <small>Empaste interior y exterior</small>
              </span>
            </label>

            <label class="radio-item">
              <input
                type="radio"
                name="obraNivel"
                value="obraHabitable"
                data-price-hormigon={prices.obraHabitableHormigon}
                data-price-metalica={prices.obraHabitableMetalica}
              />
              <span>
                <strong>Obra Habitable</strong><br/>
                <small>Cerámica cocina y baño, puertas y ventanas exteriores, pintura interior</small>
              </span>
            </label>

            <label class="radio-item">
              <input
                type="radio"
                name="obraNivel"
                value="llaveMano"
                data-price-hormigon={prices.llaveManoHormigon}
                data-price-metalica={prices.llaveManoMetalica}
              />
              <span>
                <strong>Llave en Mano</strong>
                <small>Pintura exterior, puertas interiores, mobiliario fijo(muebles cocina, armario dormitorio), cerámica/piso flotante</small>
              </span>
            </label>
          </div>
        </div>

        <!-- Total -->
        <div class="total-section">
          <h2>Estimado Total</h2>
          <div class="total-amount" id="totalAmount">$0.00</div>
          <h2>¿Está fuera de tu presupuesto?</h2>
        </div>

        <div class="actions">
          <a href="/contact" class="btn-secondary">
            Contáctanos
          </a>
        </div>
        <div class="total-section">
          <p class="disclaimer">
            * Este valor es un estimado y está sujeto a validación. Nos adaptamos
            a tus necesidades y presupuesto.
          </p>
        </div>
      </form>
    </section>
  </main>
</Layout>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement;
  const serviceTypeSelect = document.getElementById('serviceType') as HTMLSelectElement;
  const materialidadSelect = document.getElementById('materialidad') as HTMLSelectElement;
  const largoInput = document.getElementById('largo') as HTMLInputElement;
  const anchoInput = document.getElementById('ancho') as HTMLInputElement;
  const areaInput = document.getElementById('area') as HTMLInputElement;
  const numPisosInput = document.getElementById('numPisos') as HTMLInputElement;
  const checkboxes = document.querySelectorAll(
    'input[name="service"]'
  ) as NodeListOf<HTMLInputElement>;
  const obraRadios = document.querySelectorAll(
    'input[name="obraNivel"]'
  ) as NodeListOf<HTMLInputElement>;
  const totalDisplay = document.getElementById('totalAmount');
  
  const serviciosArquitectura = document.getElementById('serviciosArquitectura');
  const serviciosConstruccion = document.getElementById('serviciosConstruccion');
  const materialidadGroup = document.getElementById('materialidadGroup');

  // Calcular área automáticamente cuando cambian largo o ancho
  function calculateArea() {
    const largo = parseFloat(largoInput.value) || 0;
    const ancho = parseFloat(anchoInput.value) || 0;
    const area = largo * ancho;
    areaInput.value = area > 0 ? area.toFixed(2) : '0';
    calculateTotal();
  }

  largoInput.addEventListener('input', calculateArea);
  anchoInput.addEventListener('input', calculateArea);

  // Manejar cambio de tipo de servicio
  serviceTypeSelect.addEventListener('change', () => {
    const serviceType = serviceTypeSelect.value;
    
    // Resetear todos los campos del formulario
    largoInput.value = '';
    anchoInput.value = '';
    areaInput.value = '0';
    numPisosInput.value = '1';
    
    // Desmarcar todos los checkboxes de arquitectura
    checkboxes.forEach((checkbox) => {
      checkbox.checked = false;
    });
    
    // Desmarcar todos los radio buttons de construcción
    obraRadios.forEach((radio) => {
      radio.checked = false;
    });
    
    // Resetear materialidad a hormigón
    materialidadSelect.value = 'hormigon';
    
    if (serviceType === 'arquitectura') {
      serviciosArquitectura!.style.display = 'block';
      serviciosConstruccion!.style.display = 'none';
      materialidadGroup!.style.display = 'none';
    } else if (serviceType === 'construccion') {
      serviciosArquitectura!.style.display = 'none';
      serviciosConstruccion!.style.display = 'block';
      materialidadGroup!.style.display = 'block';
    }
    
    calculateTotal();
  });

  function calculateTotal() {
    const serviceType = serviceTypeSelect.value;
    let area = parseFloat(areaInput.value) || 0;
    let numPisos = parseFloat(numPisosInput.value) || 1;
    let total = 0;

    if (serviceType === 'arquitectura') {
      let ratePerM2 = 0;
      let fixedCost = 0;

      checkboxes.forEach((checkbox) => {
        if (checkbox.checked) {
          const price = parseFloat(checkbox.dataset.price || '0');
          if (checkbox.value === 'visita') {
            fixedCost += price;
          } else {
            ratePerM2 += price;
          }
        }
      });

      total = (ratePerM2 * area * numPisos) + fixedCost;
    } else if (serviceType === 'construccion') {
      const materialidad = materialidadSelect.value;
      const obraSeleccionada = document.querySelector('input[name="obraNivel"]:checked') as HTMLInputElement;
      
      if (obraSeleccionada) {
        const priceAttr = materialidad === 'hormigon' ? 'data-price-hormigon' : 'data-price-metalica';
        const pricePerM2 = parseFloat(obraSeleccionada.getAttribute(priceAttr) || '0');
        total = pricePerM2 * area * numPisos;
      }
    }

    if (totalDisplay) {
      totalDisplay.textContent = total.toLocaleString('en-US', {
        style: 'currency',
        currency: 'USD',
      });
    }
  }

  form.addEventListener('input', calculateTotal);

  // Validar que número de pisos sea al menos 1
  numPisosInput.addEventListener('input', () => {
    if (parseFloat(numPisosInput.value) < 1) {
      numPisosInput.value = '1';
    }
  });

  // Escuchar cambios en materialidad
  materialidadSelect.addEventListener('change', calculateTotal);

  // Escuchar cambios en nivel de obra
  obraRadios.forEach(radio => {
    radio.addEventListener('change', calculateTotal);
  });
</script>

<style>
  .container {
    margin-top: 10rem;
    padding-bottom: var(--spacing-xl);
  }

  .quote-intro {
    text-align: center;
    padding: var(--spacing-xl) 0;
    max-width: 800px;
    margin: 0 auto;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: var(--spacing-md);
  }

  .quote-form-container {
    max-width: 800px;
    margin: 0 auto;
    background-color: var(--color-background-alt);
    padding: var(--spacing-xl);
    border-radius: var(--border-radius);
    border: 1px solid var(--color-muted);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .form-group {
    margin-bottom: var(--spacing-lg);
  }

  label {
    display: block;
    margin-bottom: var(--spacing-sm);
    font-weight: 600;
    font-family: var(--font-serif);
  }

  input[type='text'],
  input[type='number'],
  select {
    width: 100%;
    padding: var(--spacing-md);
    border-radius: var(--border-radius);
    border: 1px solid var(--color-muted);
    background-color: var(--color-background);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 1rem;
    box-sizing: border-box; /* Ensure padding doesn't affect width */
  }

  input:focus,
  select:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(77, 66, 41, 0.1);
  }

  /* Dimensions Grid Layout */
  .dimensions-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: var(--spacing-md);
    align-items: end;
    margin-bottom: var(--spacing-lg);
  }

  .dimension-item {
    display: flex;
    flex-direction: column;
  }

  .dimension-item label {
    margin-bottom: var(--spacing-sm);
  }

  .dimension-separator {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-bottom: var(--spacing-md);
  }

  .multiply-symbol,
  .equals-symbol {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text-light);
  }

  .area-readonly {
    background-color: var(--color-background-alt);
    cursor: not-allowed;
    opacity: 0.7;
  }

  .checkbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--spacing-md);
  }

  .checkbox-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    cursor: pointer;
    font-weight: normal;
    padding: var(--spacing-sm);
    border-radius: var(--border-radius);
    transition: background-color 0.2s;
  }

  .checkbox-item:hover {
    background-color: var(--color-background);
  }

  input[type='checkbox'] {
    width: 20px;
    height: 20px;
    accent-color: var(--color-primary);
  }

  .radio-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .radio-item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
    cursor: pointer;
    font-weight: normal;
    padding: var(--spacing-md);
    border-radius: var(--border-radius);
    border: 2px solid var(--color-muted);
    transition: all 0.2s;
  }

  .radio-item:hover {
    border-color: var(--color-primary);
    background-color: var(--color-background);
  }

  .radio-item input[type='radio']:checked + span {
    color: var(--color-primary);
  }

  .radio-item:has(input[type='radio']:checked) {
    border-color: var(--color-primary);
    background-color: rgba(77, 66, 41, 0.05);
  }

  input[type='radio'] {
    width: 20px;
    height: 20px;
    accent-color: var(--color-primary);
    margin-top: 2px;
    flex-shrink: 0;
  }

  .radio-item span {
    flex: 1;
  }

  .radio-item small {
    display: block;
    color: var(--color-text-light);
    font-size: 0.85rem;
    margin-top: 4px;
  }

  .total-section {
    text-align: center;
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-muted);
  }

  .total-amount {
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: var(--spacing-sm) 0;
    font-family: var(--font-serif);
  }

  .disclaimer {
    font-size: 0.9rem;
    color: var(--color-text-light);
    font-style: italic;
  }

  .actions {
    margin-top: var(--spacing-lg);
    text-align: center;
  }

  .btn-secondary {
    display: inline-block;
    padding: var(--spacing-md) var(--spacing-xl);
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    border-radius: 999px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background-color: var(--color-primary);
    color: white;
  }

  @media (max-width: 768px) {
    .quote-form-container {
      padding: var(--spacing-lg);
    }
    
    .checkbox-grid {
      grid-template-columns: 1fr;
    }

    .dimensions-grid {
      grid-template-columns: 1fr auto 1fr auto 1fr;
      gap: var(--spacing-sm);
    }

    .dimension-item input {
      font-size: 0.9rem;
      padding: var(--spacing-sm);
    }

    .dimension-item label {
      font-size: 0.85rem;
    }

    .multiply-symbol,
    .equals-symbol {
      font-size: 1.2rem;
    }

    h1 {
      font-size: 2rem;
    }

    .total-amount {
      font-size: 2.5rem;
    }
  }
</style>
